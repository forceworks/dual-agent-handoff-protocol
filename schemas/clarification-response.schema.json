{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/clarification-response.schema.json",
  "title": "ClarificationResponseMessage",
  "allOf": [
    {
      "$ref": "./base-message.schema.json"
    }
  ],
  "type": "object",
  "required": [
    "answers"
  ],
  "properties": {
    "message_type": {
      "const": "CLARIFICATION_RESPONSE"
    },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "answer"],
        "properties": {
          "question": { "type": "string", "minLength": 1 },
          "answer": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "unevaluatedProperties": false
}
