{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/needs-human-decision.schema.json",
  "title": "NeedsHumanDecisionMessage",
  "allOf": [
    {
      "$ref": "./base-message.schema.json"
    }
  ],
  "type": "object",
  "required": [
    "body",
    "decision_summary"
  ],
  "properties": {
    "message_type": {
      "const": "NEEDS_HUMAN_DECISION"
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "decision_summary": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "unevaluatedProperties": false
}
