{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/clarification-request.schema.json",
  "title": "ClarificationRequestMessage",
  "allOf": [
    {
      "$ref": "./base-message.schema.json"
    }
  ],
  "type": "object",
  "required": [
    "questions"
  ],
  "properties": {
    "message_type": {
      "const": "CLARIFICATION_REQUEST"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "unevaluatedProperties": false
}
