{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/challenge.schema.json",
  "title": "ChallengeMessage",
  "allOf": [
    {
      "$ref": "./base-message.schema.json"
    }
  ],
  "type": "object",
  "required": [
    "status",
    "issues",
    "implementation_readiness"
  ],
  "properties": {
    "message_type": {
      "const": "CHALLENGE"
    },
    "status": {
      "type": "string",
      "const": "CHALLENGE"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "severity",
          "message"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "requested_clarifications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposed_adjustments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_readiness": {
      "type": "string",
      "enum": [
        "ready",
        "blocked"
      ]
    }
  },
  "unevaluatedProperties": false
}
